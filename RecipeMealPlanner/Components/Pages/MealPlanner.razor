@page "/mealplanner"
@rendermode InteractiveServer

@using RecipeMealPlanner.Models
@using RecipeMealPlanner.Services
@inject RecipeService RecipeService
@inject MealPlanService MealPlanService

<h3>Meal Planner</h3>

<div class="mb-3">
    <label>Meal Date</label>
    <InputDate class="form-control" @bind-Value="newMealPlan.MealDate" />
</div>

<div class="mb-3">
    <label>Meal Type</label>
    <select class="form-control" @bind="newMealPlan.MealType">
        <option value="">Select meal type</option>
        <option value="Breakfast">Breakfast</option>
        <option value="Lunch">Lunch</option>
        <option value="Dinner">Dinner</option>
    </select>
</div>

<div class="mb-3">
    <label>Recipe</label>
    <select class="form-control" @bind="selectedRecipeId">
        <option value="0">Select recipe</option>
        @foreach (var recipe in recipes)
        {
            <option value="@recipe.Id">@recipe.Name</option>
        }
    </select>
</div>

<button class="btn btn-primary" @onclick="AddMealPlan">Add Meal</button>

<hr />

<h4>Planned Meals</h4>

@if (mealPlans.Count == 0)
{
    <p>No meals have been planned yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Meal Type</th>
                <th>Recipe</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var meal in mealPlans)
            {
                <tr>
                    <td>@meal.MealDate.ToShortDateString()</td>
                    <td>@meal.MealType</td>
                    <td>@meal.RecipeName</td>
                    <td>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteMealPlan(meal.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Recipe> recipes = new();
    private List<MealPlan> mealPlans = new();

    private MealPlan newMealPlan = new()
    {
        MealDate = DateTime.Today
    };

    private int selectedRecipeId = 0;

    protected override void OnInitialized()
    {
        recipes = RecipeService.GetRecipes();
        mealPlans = MealPlanService.GetMealPlans();
    }

    private void AddMealPlan()
    {
        var selectedRecipe = recipes.FirstOrDefault(r => r.Id == selectedRecipeId);

        if (selectedRecipe is null || string.IsNullOrWhiteSpace(newMealPlan.MealType))
        {
            return;
        }

        var mealPlan = new MealPlan
        {
            MealDate = newMealPlan.MealDate,
            MealType = newMealPlan.MealType,
            RecipeId = selectedRecipe.Id,
            RecipeName = selectedRecipe.Name
        };

        MealPlanService.AddMealPlan(mealPlan);

        newMealPlan = new MealPlan
        {
            MealDate = DateTime.Today
        };

        selectedRecipeId = 0;
        mealPlans = MealPlanService.GetMealPlans();
    }

    private void DeleteMealPlan(int id)
    {
        MealPlanService.DeleteMealPlan(id);
        mealPlans = MealPlanService.GetMealPlans();
    }
}