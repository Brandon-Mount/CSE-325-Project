@page "/createrecipe"
@rendermode InteractiveServer
@using RecipeMealPlanner.Models
@using RecipeMealPlanner.Services
@inject RecipeService RecipeService
@inject NavigationManager Navigation

<h3>Create Recipe</h3>

<EditForm Model="recipe" OnValidSubmit="SaveRecipe">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Name</label>
        <InputText class="form-control" @bind-Value="recipe.Name" />
    </div>

    <div class="mb-3">
        <label>Category</label>
        <InputText class="form-control" @bind-Value="recipe.Category" />
    </div>

    <div class="mb-3">
        <label>Ingredients</label>
        <InputTextArea class="form-control" @bind-Value="recipe.Ingredients" />
    </div>

    <div class="mb-3">
        <label>Instructions</label>
        <InputTextArea class="form-control" @bind-Value="recipe.Instructions" />
    </div>

    <div class="mb-3">
        <label>Prep Time Minutes</label>
        <InputNumber class="form-control" @bind-Value="recipe.PrepTimeMinutes" />
    </div>

    <div class="mb-3">
        <label>Cook Time Minutes</label>
        <InputNumber class="form-control" @bind-Value="recipe.CookTimeMinutes" />
    </div>

    <div class="mb-3">
        <label>Servings</label>
        <InputNumber class="form-control" @bind-Value="recipe.Servings" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" href="/recipes">Cancel</a>
</EditForm>

@code {
    private Recipe recipe = new();

    private void SaveRecipe()
    {
        RecipeService.AddRecipe(recipe);
        Navigation.NavigateTo("/recipes");
    }
}